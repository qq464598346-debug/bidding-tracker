# ============================================
# 环境配置 - 运营商招投标AI爬虫系统
# 复制此文件为 .env 并根据实际情况修改
# ============================================

# ====== AI配置 (可选) ======
# 使用AI进行智能数据清洗和分类
# 如果不配置，系统会使用规则引擎作为备选方案
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ====== 爬虫配置 ======
# 请求间隔（秒），避免被封
CRAWL_DELAY_MIN=1
CRAWL_DELAY_MAX=3

# 单次采集每源最大条数
MAX_ITEMS_PER_SOURCE=50

# 浏览器自动化超时（毫秒）
BROWSER_TIMEOUT=30000

# 是否使用无头模式运行浏览器
HEADLESS=true

# ====== 数据库配置 ======
# 数据库路径（默认在项目data目录下）
DATABASE_PATH=./data/bidding.db

# ====== API服务配置 ======
API_HOST=0.0.0.0
API_PORT=8765
API_DEBUG=true

# ====== 定时任务配置 ======
# 定时采集间隔（分钟），0表示不启用定时采集
CRON_INTERVAL_MINUTES=60
